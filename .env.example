# ─────────────────────────────────────────────────────────
# CricketVerse — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── Database (self-hosted MySQL 8) ──────────────────────
# Server-side only — deliberately NOT NEXT_PUBLIC_*, so none of this is
# bundled into the browser. Apply the schema with:
#   mysql -u quickcric -p quickcric < database/mysql/001_schema.sql
#   mysql -u quickcric -p quickcric < database/mysql/002_seed.sql
#
# In production the app runs in Docker and reaches MySQL over the host's
# unix socket (bind-mounted by docker-compose.prod.yml), which lets MySQL
# keep bind-address 127.0.0.1 and publish no port at all. Set DB_SOCKET
# for that; for local development leave it empty and use DB_HOST/DB_PORT.
DB_SOCKET=/var/run/mysqld/mysqld.sock
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=quickcric
DB_PASSWORD=your_mysql_password_here
DB_NAME=quickcric

# ── App URLs ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SIM_URL=http://localhost:8000
NEXT_PUBLIC_MP_URL=ws://localhost:8001

# ── Google AdSense (optional — ads stay off until both set) ──
# Client from adsense.google.com after approval; slot = a responsive
# display ad unit id. Both are baked into the frontend at BUILD time.
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-0000000000000000
# NEXT_PUBLIC_ADSENSE_SLOT=0000000000

# ── Anthropic (AI commentary + AI Coach) ─────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx

# ── CricAPI (real player stats — cricapi.com) ────────────
CRICAPI_KEY=your_cricapi_key_here

# ── Stripe (billing) ─────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_ELITE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_ELITE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

# ── Admin ────────────────────────────────────────────────
ADMIN_SECRET_KEY=your_admin_secret_key_here

# ── ElevenLabs (optional — premium voice commentary) ─────
# ELEVENLABS_API_KEY=your_elevenlabs_key_here

# ── Redis (optional — for session caching) ───────────────
REDIS_URL=redis://localhost:6379
